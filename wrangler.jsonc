{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "flora",
  "main": "src/worker.js",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "flora.clydeford.net",
      "custom_domain": true
    }
  ]
}
